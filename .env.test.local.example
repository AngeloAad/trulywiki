# Testing Environment Variables

# Database
# Note: For E2E tests, it's recommended to use a separate testing database or Neon branch
DATABASE_URL="postgresql://user:pass@host.neon.tech/db"

# Neon Auth
NEON_AUTH_BASE_URL="your-neon-auth-base-url"
NEON_AUTH_COOKIE_SECRET="your-neon-auth-cookie-secret"

# Test User Credentials (Create this user in Neon Auth manually)
TEST_USER_EMAIL="test@example.com"
TEST_USER_PASSWORD="your-test-password"

# Upstash Redis
UPSTASH_REDIS_REST_URL="your-test-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-test-redis-token"

# AI Providers
AI_GATEWAY_API_KEY="your-vercel-ai-key"
OPENAI_API_KEY="your-openai-api-key"
